{
  "name": "@muyichengshayu/promptx",
  "version": "0.1.9",
  "description": "PromptX 本机 AI 协作工作台",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "promptx": "./bin/promptx.js"
  },
  "files": [
    "bin",
    "apps/server/src",
    "!apps/server/src/**/*.test.js",
    "apps/web/dist",
    "packages/shared/src",
    "scripts/doctor.mjs",
    "scripts/relay.mjs",
    "scripts/relay-service.mjs",
    "scripts/relay-tenant.mjs",
    "scripts/service.mjs",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0 <23 || >=24 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:tailscale": "node scripts/dev-tailscale.mjs",
    "dev:tailscale:auto": "node scripts/dev-tailscale.mjs --auto",
    "build": "pnpm -r build",
    "start": "pnpm build && node scripts/service.mjs start",
    "stop": "node scripts/service.mjs stop",
    "restart": "pnpm stop && pnpm build && node scripts/service.mjs start",
    "status": "node scripts/service.mjs status",
    "doctor": "node scripts/doctor.mjs",
    "relay:start": "node scripts/relay.mjs",
    "release:check": "node scripts/release.mjs check",
    "release": "node scripts/release.mjs publish",
    "prepack": "pnpm build",
    "pack:dry": "npm pack --dry-run",
    "lint": "pnpm -r lint",
    "smoke:realtime": "node scripts/smoke-realtime-sync.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/static": "9.0.0",
    "@napi-rs/canvas": "0.1.96",
    "better-sqlite3": "12.8.0",
    "fastify": "5.8.2",
    "iconv-lite": "0.7.2",
    "jimp": "1.6.0",
    "nanoid": "5.1.6",
    "pdfjs-dist": "5.5.207",
    "sql.js": "1.13.0",
    "ws": "8.18.3"
  }
}
